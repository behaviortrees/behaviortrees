# Cloud sync (optional — without these the editor runs local-only, as before)

# Client: Clerk publishable key; enables the sign-in UI and sync engine
VITE_CLERK_PUBLISHABLE_KEY=

# Functions only (vercel dev / Vercel project settings, never exposed to the client)
CLERK_SECRET_KEY=
DATABASE_URL=

# Admin dashboard (functions only)
ADMIN_USER_IDS=            # comma-separated Clerk user ids allowed on /api/admin/*
PLAUSIBLE_API_KEY=         # plausible.io -> Settings -> API keys (Stats API)
PLAUSIBLE_SITE_ID=behaviortrees.com
POSTHOG_API_KEY=           # personal API key (phx_...) with query:read scope
POSTHOG_PROJECT_ID=        # numeric project id from PostHog settings (US cloud)

# Client: hides the Admin nav link for everyone else (server still enforces)
VITE_ADMIN_USER_IDS=
