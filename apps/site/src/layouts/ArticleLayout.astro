---
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? Astro.props.title;
const description = frontmatter?.description ?? Astro.props.description;
const pubDate = frontmatter?.pubDate;
const updatedDate = frontmatter?.updatedDate;
const isArticle = !!frontmatter;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Amazon Associates tag — placeholder until the Associates account is approved.
const amazonTag = 'behaviortrees-20';
const books = [
    {
        title: 'Behavior Trees in Robotics and AI: An Introduction',
        authors: 'Michele Colledanchise & Petter Ögren',
        blurb: 'The definitive behavior tree reference, from theory through robotics practice.',
        asin: '1138593737',
    },
    {
        title: 'AI for Games, Third Edition',
        authors: 'Ian Millington',
        blurb: 'The standard game-AI textbook, including decision-making and behavior trees.',
        asin: '1138483974',
    },
    {
        title: 'Programming Game AI by Example',
        authors: 'Mat Buckland',
        blurb: 'A classic hands-on introduction to agent architectures for games.',
        asin: '1556220782',
    },
];

const jsonLd = isArticle
    ? {
          '@context': 'https://schema.org',
          '@type': 'TechArticle',
          headline: title,
          description: description,
          url: canonical,
          ...(pubDate ? { datePublished: pubDate } : {}),
          ...(updatedDate ? { dateModified: updatedDate } : {}),
          author: { '@type': 'Organization', name: 'behaviortrees.com', url: 'https://www.behaviortrees.com/' },
          publisher: { '@type': 'Organization', name: 'behaviortrees.com', url: 'https://www.behaviortrees.com/' },
      }
    : null;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" type="image/x-icon" href="/imgs/favicon.ico" />

    <!-- Must run before any stylesheet so the first style resolution already
         sees the theme. Kept byte-identical with the editor app's index.html;
         both sites share one origin, so they share the bt-theme key. -->
    <script is:inline>
        (function () {
            try {
                var t = localStorage.getItem('bt-theme') || 'system',
                    d = t === 'dark' || (t !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches),
                    r = document.documentElement;
                r.dataset.theme = d ? 'dark' : 'light';
                r.style.colorScheme = d ? 'dark' : 'light';
            } catch (e) {
                document.documentElement.dataset.theme = 'dark';
            }
        })();
    </script>
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:site_name" content="behaviortrees.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://www.behaviortrees.com/imgs/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.behaviortrees.com/imgs/og-image.png" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script async src="/pl/js/script.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init({ endpoint: "/pl/api/event" })
    </script>
</head>
<body>
    <header class="site-header">
        <nav>
            <a class="wordmark" href="/learn/">behaviortrees<span>.com</span></a>
            <div class="nav-links">
                <a href="/learn/">Learn</a>
                <a class="cta" href="/">Open Editor</a>
                <button
                    type="button"
                    id="theme-toggle"
                    class="theme-pill"
                    role="switch"
                    aria-checked="false"
                    aria-label="Toggle theme"
                    title="Toggle theme"
                >
                    <span class="knob"></span>
                </button>
            </div>
        </nav>
    </header>

    <script is:inline>
        (function () {
            var btn = document.getElementById('theme-toggle');
            if (!btn) return;
            var sync = function () {
                var light = document.documentElement.dataset.theme === 'light';
                btn.setAttribute('aria-checked', String(light));
            };
            sync();
            btn.addEventListener('click', function () {
                var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
                localStorage.setItem('bt-theme', next);
                document.documentElement.dataset.theme = next;
                document.documentElement.style.colorScheme = next;
                sync();
            });
            // Follow the editor app changing the theme in another tab
            window.addEventListener('storage', function (e) {
                if (e.key && e.key !== 'bt-theme') return;
                var t = localStorage.getItem('bt-theme') || 'system';
                var d = t === 'dark' || (t !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches);
                document.documentElement.dataset.theme = d ? 'dark' : 'light';
                document.documentElement.style.colorScheme = d ? 'dark' : 'light';
                sync();
            });
        })();
    </script>

    <main>
        <article>
            <slot />
        </article>

        <!-- Ad slot: activate after EthicalAds/Carbon approval.
             https://www.ethicalads.io/publishers/
        <div class="ad-slot" data-ea-publisher="behaviortreescom" data-ea-type="text"></div>
        -->

        <section class="reading">
            <h2>Recommended reading</h2>
            <p>Books that go deeper on behavior trees and game AI.</p>
            <ul>
                {
                    books.map((book) => (
                        <li>
                            <a
                                href={`https://www.amazon.com/dp/${book.asin}?tag=${amazonTag}`}
                                rel="sponsored noopener"
                                target="_blank"
                            >
                                {book.title}
                            </a>
                            <span class="authors"> — {book.authors}.</span> {book.blurb}
                        </li>
                    ))
                }
            </ul>
            <p class="affiliate-note">
                As an Amazon Associate, behaviortrees.com earns from qualifying purchases.
            </p>
        </section>
    </main>

    <footer class="site-footer">
        <p>
            <a href="/learn/">Guides</a> ·
            <a href="/">Behavior Tree Editor</a> ·
            <a href="https://old.behaviortrees.com">Classic editor</a> ·
            <a href="https://github.com/behaviortrees/behaviortrees">GitHub</a>
        </p>
        <p>© {new Date().getFullYear()} behaviortrees.com. Editor based on the MIT-licensed behavior3editor.</p>
    </footer>
</body>
</html>


<style is:global>
    /* ──────────────────────────────────────────────────────────────────────
       Nocturne — the same Layer B token block the editor app carries in
       src/index.css. Kept as plain CSS on purpose so it ports between the
       Tailwind app and this Astro site without translation.
       ────────────────────────────────────────────────────────────────────── */
    @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('/fonts/inter-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
            U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212,
            U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('/fonts/inter-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304,
            U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0,
            U+2113, U+2C60-2C7F, U+A720-A7FF;
    }

    :root,
    [data-theme='dark'] {
        color-scheme: dark;
        --bt-bg: #161826;
        --bt-text: #e9e9ed;
        --bt-accent: #9184d9;
        --bt-divider: color-mix(in srgb, #e9e9ed 16%, transparent);
        --mut: #9397ab;
        --faint: #75798c;
        --brd: #3f424d;
        --panel: #232532;
        --inputbg: #1c1e2b;
        --acc-soft: #d2cefd;
        --acc-deep: #b5abfc;
        --glow: rgba(145, 132, 217, 0.32);
    }

    [data-theme='light'] {
        color-scheme: light;
        --bt-bg: #e4e7f5;
        --bt-text: #292b31;
        --bt-divider: color-mix(in srgb, #292b31 16%, transparent);
        --mut: #595d6c;
        --faint: #75798c;
        --brd: #b2b6ca;
        --panel: #f3f5fe;
        --inputbg: #e4e7f5;
        --acc-soft: #5d5294;
        --acc-deep: #5d5294;
        --glow: rgba(145, 132, 217, 0.45);
    }

    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: var(--bt-bg);
        color: var(--bt-text);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.65;
        font-size: 15px;
    }

    :focus {
        outline: none;
    }
    :focus-visible {
        outline: 2px solid var(--bt-accent);
        outline-offset: 2px;
    }
    ::selection {
        background: color-mix(in srgb, var(--bt-accent) 30%, transparent);
    }

    /* — header — */
    .site-header {
        position: sticky;
        top: 0;
        z-index: 2;
        background: var(--bt-bg);
        border-bottom: 1px solid var(--bt-divider);
    }
    .site-header nav {
        height: 54px;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .wordmark {
        font-weight: 500;
        font-size: 15px;
        text-decoration: none;
        color: var(--bt-text);
        letter-spacing: -0.01em;
    }
    .wordmark span {
        color: var(--acc-deep);
    }
    .nav-links {
        display: flex;
        gap: 18px;
        align-items: center;
    }
    .nav-links a {
        color: var(--mut);
        text-decoration: none;
        font-size: 13px;
        transition: color 0.15s;
    }
    .nav-links a:hover {
        color: var(--acc-soft);
    }
    /* Outlined, never a solid accent fill — the system's core button rule. */
    .nav-links a.cta {
        border: 1px solid var(--bt-accent);
        border-radius: 8px;
        color: var(--acc-soft);
        font-weight: 500;
        padding: 7px 16px;
        transition: background 0.15s;
    }
    .nav-links a.cta:hover {
        background: color-mix(in srgb, var(--bt-accent) 14%, transparent);
    }

    .theme-pill {
        position: relative;
        display: inline-block;
        width: 34px;
        height: 19px;
        padding: 0;
        border: 1px solid var(--brd);
        border-radius: 10px;
        background: transparent;
        cursor: pointer;
        transition: border-color 0.15s;
    }
    .theme-pill:hover {
        border-color: var(--bt-accent);
    }
    .theme-pill .knob {
        position: absolute;
        top: 2px;
        left: 2px;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        background: var(--bt-accent);
        transition: transform 0.18s;
    }
    .theme-pill[aria-checked='true'] .knob {
        transform: translateX(15px);
    }

    /* — layout — */
    /* Flush-left and asymmetric: the column hugs the left edge on wide
       viewports and the whitespace falls on the right. */
    main {
        max-width: 48rem;
        margin: 0 auto 0 max(1.25rem, calc(50vw - 33rem));
        padding: 4rem 1.25rem 5rem;
    }

    /* — article type — */
    article h1 {
        font-size: 40px;
        font-weight: 500;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 0 0 0.9rem;
        text-wrap: balance;
    }
    article h2 {
        font-size: 25px;
        font-weight: 500;
        letter-spacing: -0.015em;
        margin: 2.75rem 0 0.75rem;
    }
    article h3 {
        font-size: 20px;
        font-weight: 500;
        margin: 2rem 0 0.5rem;
    }
    article p,
    article li {
        color: var(--bt-text);
        text-wrap: pretty;
    }
    article > p:first-of-type {
        font-size: 17px;
        color: var(--mut);
    }
    /* Accent-on-ground is only ~3:1, so paragraph-size accent text takes the
       lighter ramp step rather than the accent itself. */
    article a {
        color: var(--acc-soft);
        text-decoration: none;
        text-underline-offset: 3px;
    }
    article a:hover {
        text-decoration: underline;
    }
    article img {
        max-width: 100%;
    }

    article code {
        background: var(--inputbg);
        border: 1px solid var(--brd);
        border-radius: 4px;
        padding: 0.1em 0.35em;
        font-size: 0.875em;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    article pre {
        background: var(--inputbg);
        border: 1px solid var(--brd);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        overflow-x: auto;
        line-height: 1.5;
    }
    article pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.85rem;
    }

    article blockquote {
        margin: 1.5rem 0;
        padding: 0.25rem 1.25rem;
        border-left: 2px solid var(--bt-accent);
        color: var(--mut);
    }

    article table {
        border-collapse: collapse;
        width: 100%;
        margin: 1.5rem 0;
        font-size: 14px;
        display: block;
        overflow-x: auto;
    }
    article th,
    article td {
        border-bottom: 1px solid var(--bt-divider);
        padding: 0.5rem 0.75rem;
        text-align: left;
        vertical-align: top;
    }
    article th {
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
        color: var(--mut);
    }

    .try-editor {
        display: inline-block;
        border: 1px solid var(--bt-accent);
        border-radius: 8px;
        color: var(--acc-soft) !important;
        text-decoration: none !important;
        font-weight: 500;
        font-size: 13px;
        padding: 8px 18px;
        margin: 0.5rem 0 1rem;
        transition: background 0.15s;
    }
    .try-editor:hover {
        background: color-mix(in srgb, var(--bt-accent) 14%, transparent);
    }

    .disclosure {
        font-size: 13px;
        color: var(--mut);
        background: var(--panel);
        border: 1px solid var(--brd);
        border-radius: 8px;
        padding: 0.6rem 1rem;
        margin: 1.5rem 0;
    }

    .ad-slot {
        margin: 2.5rem 0;
    }

    /* — recommended reading — */
    .reading {
        margin-top: 3.5rem;
        border: 1px solid var(--brd);
        background: var(--panel);
        border-radius: 14px;
        padding: 1.75rem 2rem;
    }
    .reading h2 {
        margin: 0 0 0.4rem;
        font-size: 17px;
        font-weight: 500;
    }
    .reading p {
        margin: 0 0 1rem;
        color: var(--mut);
        font-size: 13.5px;
    }
    .reading ul {
        margin: 0;
        padding-left: 1.1rem;
        font-size: 14px;
    }
    .reading li {
        margin-bottom: 0.6rem;
        color: var(--mut);
    }
    .reading li a {
        color: var(--acc-soft);
        text-decoration: none;
        text-underline-offset: 3px;
    }
    .reading li a:hover {
        text-decoration: underline;
    }
    .reading .authors {
        color: var(--bt-text);
    }
    .reading .affiliate-note {
        margin: 1rem 0 0;
        font-size: 12px;
        color: var(--faint);
    }

    /* — footer — */
    .site-footer {
        border-top: 1px solid var(--bt-divider);
        padding: 1.5rem 1.25rem 2.5rem;
        text-align: center;
        color: var(--mut);
        font-size: 13px;
    }
    .site-footer a {
        color: var(--mut);
        text-decoration: none;
    }
    .site-footer a:hover {
        color: var(--acc-soft);
    }

    /* — guide index — */
    .article-list {
        list-style: none;
        padding: 0;
        margin: 2.5rem 0 0;
    }
    /* Rules fade to transparent at their ends — a Nocturne signature. */
    .article-list li {
        padding: 22px 0;
        border-bottom: 1px solid transparent;
        border-image: linear-gradient(90deg, var(--bt-divider), transparent) 1;
    }
    .article-list a {
        font-weight: 500;
        font-size: 19px;
        letter-spacing: -0.01em;
        text-decoration: none;
        color: var(--acc-soft);
    }
    .article-list a:hover {
        text-decoration: underline;
    }
    .article-list p {
        margin: 0.4rem 0 0;
        color: var(--mut);
        font-size: 13.5px;
        line-height: 1.55;
        max-width: 38rem;
    }

    @media (max-width: 900px) {
        main {
            margin: 0 auto;
        }
    }
</style>
